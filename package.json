{
  "name": "@oruga-ui/theme-oruga",
  "version": "0.8.3",
  "description": "Default theme for Oruga",
  "license": "MIT",
  "type": "module",
  "main": "dist/theme.js",
  "module": "dist/theme.js",
  "unpkg": "dist/theme.js",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "exports": {
    ".": "./dist/theme.js",
    "./style.css": "./dist/theme.css",
    "./style.scss": "./dist/scss/theme.scss",
    "./scss/*": "./dist/scss/*.scss",
    "./dist/scss/*": "./dist/scss/*.scss"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oruga-ui/theme-oruga.git"
  },
  "bugs": {
    "url": "https://github.com/oruga-ui/theme-oruga/issues"
  },
  "scripts": {
    "dev": "vite --force",
    "serve": "vite preview",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "run-s lint:eslint lint:prettier lint:stylelint",
    "lint:eslint": "eslint . --fix",
    "lint:prettier": "prettier --write .",
    "lint:stylelint": "stylelint **/*.{css,scss} --fix --ignore-path .gitignore",
    "test:lint": "run-s test:eslint test:prettier test:stylelint",
    "test:eslint": "eslint .",
    "test:prettier": "prettier --check .",
    "test:stylelint": "stylelint **/*.{css,scss} --ignore-path .gitignore",
    "update": "ncu -u"
  },
  "peerDependencies": {
    "@oruga-ui/oruga-next": "^0.13.0-pre.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@oruga-ui/examples": "^0.13.0-pre.2",
    "@oruga-ui/oruga-next": "^0.13.0-pre.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "conventional-changelog-conventionalcommits": "^9.2.0",
    "core-js": "3.48.0",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "npm-check-updates": "^19.6.3",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "sass": "1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vue": "^3.5.29",
    "vue-router": "5.0.3",
    "vue-tsc": "^3.2.5"
  }
}
